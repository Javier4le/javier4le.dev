---
// No props — navigation is global
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a
        href="#"
        class="font-mono text-xl font-bold text-foreground hover:text-primary transition-colors"
      >
        <span class="text-primary">&lt;</span>JR<span class="text-accent">/</span><span class="text-primary">&gt;</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="font-medium text-muted-foreground hover:text-primary transition-colors relative group">
          About
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href="#projects" class="font-medium text-muted-foreground hover:text-primary transition-colors relative group">
          Projects
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href="#skills" class="font-medium text-muted-foreground hover:text-primary transition-colors relative group">
          Skills
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href="#contact" class="font-medium text-muted-foreground hover:text-primary transition-colors relative group">
          Contact
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all duration-300 group-hover:w-full"></span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="hamburger"
        class="md:hidden text-foreground hover:text-primary transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <!-- Hamburger icon -->
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <!-- Close icon -->
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div
      id="mobile-menu"
      class="md:hidden hidden mt-4 pb-4 border-t border-border pt-4"
    >
      <div class="flex flex-col gap-4">
        <a href="#about" class="font-medium text-muted-foreground hover:text-primary transition-colors">About</a>
        <a href="#projects" class="font-medium text-muted-foreground hover:text-primary transition-colors">Projects</a>
        <a href="#skills" class="font-medium text-muted-foreground hover:text-primary transition-colors">Skills</a>
        <a href="#contact" class="font-medium text-muted-foreground hover:text-primary transition-colors">Contact</a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Scroll detection
  const nav = document.getElementById('main-nav')
  window.addEventListener('scroll', () => {
    if (!nav) return
    if (window.scrollY > 8) {
      nav.classList.add('is-scrolled')
    } else {
      nav.classList.remove('is-scrolled')
    }
  }, { passive: true })

  // Mobile toggle
  const hamburger = document.getElementById('hamburger')
  const mobileMenu = document.getElementById('mobile-menu')
  const iconMenu = document.getElementById('icon-menu')
  const iconClose = document.getElementById('icon-close')

  hamburger?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden')
    if (isOpen) {
      mobileMenu?.classList.add('hidden')
      iconMenu?.classList.remove('hidden')
      iconClose?.classList.add('hidden')
      hamburger.setAttribute('aria-expanded', 'false')
    } else {
      mobileMenu?.classList.remove('hidden')
      iconMenu?.classList.add('hidden')
      iconClose?.classList.remove('hidden')
      hamburger.setAttribute('aria-expanded', 'true')
    }
  })

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden')
      iconMenu?.classList.remove('hidden')
      iconClose?.classList.add('hidden')
      hamburger?.setAttribute('aria-expanded', 'false')
    })
  })
</script>

<style>
  #main-nav.is-scrolled {
    background-color: color-mix(in srgb, var(--background) 90%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
</style>
