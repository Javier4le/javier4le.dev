---
// Isometric desk setup — decorative SVG, no props needed
---

<div
  class="relative w-full max-w-lg mx-auto"
  style="filter: drop-shadow(0 0 30px rgba(255, 0, 128, 0.3))"
>
  <svg
    viewBox="0 0 400 350"
    class="w-full h-auto"
    aria-hidden="true"
  >
    <!-- Desk -->
    <path d="M50 220 L200 280 L350 220 L200 160 Z" fill="#1a1a24" stroke="#2a2a3a" stroke-width="2" />
    <path d="M50 220 L50 260 L200 320 L200 280 Z" fill="#12121a" stroke="#2a2a3a" stroke-width="1" />
    <path d="M200 280 L200 320 L350 260 L350 220 Z" fill="#0f0f14" stroke="#2a2a3a" stroke-width="1" />

    <!-- Main Monitor -->
    <rect x="130" y="80" width="140" height="90" fill="#0a0a0f" stroke="#ff0080" stroke-width="2" />
    <rect x="135" y="85" width="130" height="75" fill="#12121a" />
    <!-- Screen content — code lines -->
    <line x1="145" y1="95" x2="200" y2="95" stroke="#00f5ff" stroke-width="2" opacity="0.8" />
    <line x1="145" y1="105" x2="180" y2="105" stroke="#ff0080" stroke-width="2" opacity="0.6" />
    <line x1="155" y1="115" x2="220" y2="115" stroke="#7c3aed" stroke-width="2" opacity="0.7" />
    <line x1="155" y1="125" x2="190" y2="125" stroke="#00f5ff" stroke-width="2" opacity="0.5" />
    <line x1="145" y1="135" x2="210" y2="135" stroke="#ff0080" stroke-width="2" opacity="0.6" />
    <line x1="145" y1="145" x2="175" y2="145" stroke="#7c3aed" stroke-width="2" opacity="0.8" />
    <!-- Monitor stand -->
    <rect x="190" y="170" width="20" height="25" fill="#2a2a3a" />
    <ellipse cx="200" cy="200" rx="30" ry="8" fill="#1a1a24" stroke="#2a2a3a" stroke-width="1" />

    <!-- Second Monitor (smaller, angled) -->
    <g transform="rotate(-15, 80, 130)">
      <rect x="40" y="100" width="80" height="55" fill="#0a0a0f" stroke="#00f5ff" stroke-width="1.5" />
      <rect x="43" y="103" width="74" height="46" fill="#12121a" />
      <line x1="50" y1="112" x2="90" y2="112" stroke="#ff0080" stroke-width="1.5" opacity="0.7" />
      <line x1="50" y1="120" x2="75" y2="120" stroke="#00f5ff" stroke-width="1.5" opacity="0.5" />
      <line x1="50" y1="128" x2="100" y2="128" stroke="#7c3aed" stroke-width="1.5" opacity="0.6" />
      <rect x="75" y="155" width="10" height="15" fill="#2a2a3a" />
    </g>

    <!-- Keyboard -->
    <path d="M160 230 L240 230 L250 250 L150 250 Z" fill="#1a1a24" stroke="#7c3aed" stroke-width="1.5" />
    <!-- RGB keyboard glow -->
    <line x1="165" y1="238" x2="175" y2="238" stroke="#ff0080" stroke-width="2" opacity="0.8" />
    <line x1="180" y1="238" x2="190" y2="238" stroke="#00f5ff" stroke-width="2" opacity="0.8" />
    <line x1="195" y1="238" x2="205" y2="238" stroke="#7c3aed" stroke-width="2" opacity="0.8" />
    <line x1="210" y1="238" x2="220" y2="238" stroke="#ff0080" stroke-width="2" opacity="0.8" />
    <line x1="225" y1="238" x2="235" y2="238" stroke="#00f5ff" stroke-width="2" opacity="0.8" />

    <!-- Mouse -->
    <ellipse cx="280" cy="245" rx="12" ry="18" fill="#1a1a24" stroke="#00f5ff" stroke-width="1.5" />
    <line x1="280" y1="232" x2="280" y2="240" stroke="#ff0080" stroke-width="2" />

    <!-- Plant -->
    <ellipse cx="320" cy="210" rx="15" ry="8" fill="#1a1a24" stroke="#2a2a3a" stroke-width="1" />
    <path d="M315 205 Q310 185 320 180 Q330 185 325 205" fill="none" stroke="#00ff88" stroke-width="2" />
    <path d="M318 200 Q308 180 318 170 Q328 175 322 195" fill="none" stroke="#00ff88" stroke-width="2" opacity="0.7" />
    <path d="M322 202 Q332 182 325 172" fill="none" stroke="#00ff88" stroke-width="2" opacity="0.8" />

    <!-- RGB ambient light effect -->
    <ellipse cx="200" cy="250" rx="100" ry="20" fill="url(#rgbGradient)" opacity="0.3" />

    <defs>
      <linearGradient id="rgbGradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#ff0080" />
        <stop offset="50%" stop-color="#7c3aed" />
        <stop offset="100%" stop-color="#00f5ff" />
      </linearGradient>
    </defs>
  </svg>
</div>
