---
import type { Profile } from '../types/index'

interface Props {
  profile: Profile
}

const { profile } = Astro.props

const currentYear = new Date().getFullYear()
---

<footer class="border-t border-border py-8">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <!-- Copyright -->
      <p class="font-mono text-sm text-muted-foreground">
        &copy; {currentYear} Javier Rojas
      </p>

      <!-- Built with -->
      <p class="font-mono text-xs text-muted-foreground">
        Hecho con <span class="text-primary">Astro</span> + <span class="text-accent">Tailwind CSS</span>
      </p>

      <!-- Social links -->
      <div class="flex items-center gap-4">
        <a
          href={profile.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-primary transition-colors font-mono text-sm"
          aria-label="GitHub"
        >
          GitHub
        </a>
        <a
          href={profile.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-accent transition-colors font-mono text-sm"
          aria-label="LinkedIn"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
