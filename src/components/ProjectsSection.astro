---
import type { Project } from '../types'
import ProjectCard from './ProjectCard.astro'

interface Props {
  projects: Project[]
}

const { projects } = Astro.props
---

<section id="projects" class="py-24 relative" data-animate>
  <div class="max-w-6xl mx-auto px-6">
    <!-- Heading -->
    <div>
      <h2 class="text-3xl md:text-4xl font-bold mb-2">
        <span class="text-primary font-mono">&gt;</span> Projects
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-primary to-accent mb-8"></div>
    </div>

    <!-- Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, i) => (
        <div data-animate data-animate-delay={`${(i + 1) * 100}`}>
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </div>
</section>
